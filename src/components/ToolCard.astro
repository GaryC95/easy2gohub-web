---
const {
  href = "#",
  icon = "apps",
  title = "Tool",
  description = "",
  badge,
} = Astro.props as {
  href?: string;
  icon?: string;
  title?: string;
  description?: string;
  badge?: string;
};

const searchHay = `${title} ${description} ${badge ?? ""}`.toLowerCase();
---

<a
  href={href}
  data-tool-card
  data-search={searchHay}
  class="group block relative rounded-2xl border border-slate-200/70 bg-white/75 backdrop-blur
         transition will-change-transform
         shadow-[0_10px_24px_rgba(2,6,23,0.08)]
         hover:-translate-y-[2px] hover:bg-white/90 hover:shadow-[0_18px_44px_rgba(2,6,23,0.14)]
         active:translate-y-0 active:shadow-[0_8px_18px_rgba(2,6,23,0.10)] active:scale-[0.995]
         focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500/20"
>
  {/* subtle top highlight (让它更像可按按钮) */}
  <div class="pointer-events-none absolute inset-0 rounded-2xl bg-gradient-to-b from-white/55 to-transparent opacity-70"></div>

  <div class="relative p-6">
    <div class="flex items-start justify-between gap-3">
      <div class="flex items-center gap-3 min-w-0">
        <span class="material-symbols-outlined text-primary">{icon}</span>
        <h3 class="font-semibold text-slate-900 truncate">{title}</h3>
      </div>

      {badge ? (
        <span class="shrink-0 text-[10px] font-semibold uppercase tracking-wider px-2 py-1 rounded-full bg-primary/10 text-primary">
          {badge}
        </span>
      ) : null}
    </div>

    <p class="text-sm text-slate-600 mt-2 leading-relaxed line-clamp-2">
      {description}
    </p>

    <div
      class="mt-4 inline-flex items-center gap-2 text-xs font-semibold
             text-slate-500 group-hover:text-primary transition-colors"
    >
      Open
      <span class="material-symbols-outlined text-base">arrow_forward</span>
    </div>
  </div>
</a>