---
const { tools = [] } = Astro.props as {
  tools?: Array<{
    category: string;
    slug: string;
    title: string;
    description: string;
    icon?: string;
    badge?: string;
  }>;
};

import ToolCard from "./ToolCard.astro";
---

<div class="w-full min-w-0 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
  {tools.map((t) => (
    <ToolCard
      href={`/${t.category}/${t.slug}/`}
      icon={t.icon || "apps"}
      title={t.title}
      description={t.description}
      badge={t.badge}
    />
  ))}
</div>