---
type Variant = "box" | "banner";

const {
  label = "Sponsored",
  height = "h-40",              // string class or number px
  className = "",
  variant = "box",

  // AdSense
  adSlot,
  adFormat = "auto",
  responsive = true,

  // ✅ new
  showPlaceholder = false,      // 默认不显示 Reserved Space
  preserveSpace = false,        // true: 预留高度但不显示任何UI（更“专业”）
  hideLabel = false,            // true: 隐藏顶部小标签行
} = Astro.props as {
  label?: string;
  height?: string | number;
  className?: string;
  variant?: Variant;

  adSlot?: string | number;
  adFormat?: string;
  responsive?: boolean;

  showPlaceholder?: boolean;
  preserveSpace?: boolean;
  hideLabel?: boolean;
};

const AD_CLIENT = "ca-pub-1409463603356964";
const enabled = import.meta.env.PROD;
const uid = `ads_${Math.random().toString(16).slice(2)}_${Date.now().toString(16)}`;

const canRenderReal = enabled && !!adSlot;

// ✅ height handling
const heightClass = typeof height === "string" ? height : "";
const heightStyle = typeof height === "number" ? `height:${height}px;` : "";

// ✅ 是否渲染：
// - 有真实广告：渲染
// - 或者你明确要求 showPlaceholder / preserveSpace：渲染
// - 否则（最重要）：直接不渲染（不占位、不出现 Reserved Space）
const shouldRender = canRenderReal || showPlaceholder || preserveSpace;

// ✅ container style
const containerClass =
  (preserveSpace && !canRenderReal && !showPlaceholder)
    ? `rounded-2xl overflow-hidden ${heightClass} ${className}`.trim()
    : `tool-card glass rounded-2xl overflow-hidden border border-slate-200/70 shadow-[0_16px_50px_rgba(2,6,23,0.06)] ${heightClass} ${className}`.trim();

const variantTag = variant.toUpperCase();
---

{shouldRender ? (
  <div class={containerClass} data-ads-uid={uid} style={heightStyle}>
    {(!hideLabel && (canRenderReal || showPlaceholder)) ? (
      <div class="px-4 pt-4 flex items-center justify-between text-[10px] font-semibold tracking-wider uppercase text-slate-400">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-slate-400 text-base">ads_click</span>
          <span>{label}</span>
        </div>
        <span class="text-slate-300">{variantTag}</span>
      </div>
    ) : null}

    <div class={(!hideLabel && (canRenderReal || showPlaceholder)) ? "px-4 pb-4 pt-3 h-full" : "h-full"}>
      {canRenderReal ? (
        <div class="w-full h-full flex items-center justify-center">
          <ins
            class="adsbygoogle"
            style={`display:block; width:100%; height:100%; ${heightStyle}`}
            data-ad-client={AD_CLIENT}
            data-ad-slot={String(adSlot)}
            data-ad-format={adFormat}
            data-full-width-responsive={responsive ? "true" : "false"}
          ></ins>

          <script is:inline>
            {`
              (function(){
                try {
                  const root = document.currentScript?.closest('[data-ads-uid]');
                  if (!root) return;
                  if (root.dataset.adsInit === "1") return;
                  root.dataset.adsInit = "1";

                  const ins = root.querySelector('ins.adsbygoogle');
                  window.adsbygoogle = window.adsbygoogle || [];
                  window.adsbygoogle.push({});

                  // ✅ collapse unfilled ads (AdSense 会打 data-ad-status="unfilled")
                  const collapseIfUnfilled = () => {
                    try {
                      if (!ins) return;
                      const st = ins.getAttribute('data-ad-status');
                      if (st === 'unfilled') {
                        root.style.display = 'none';
                      }
                    } catch(e){}
                  };

                  collapseIfUnfilled();
                  if (ins && window.MutationObserver) {
                    const mo = new MutationObserver(collapseIfUnfilled);
                    mo.observe(ins, { attributes:true, attributeFilter:['data-ad-status'] });
                    setTimeout(collapseIfUnfilled, 1500);
                  }
                } catch (e) {}
              })();
            `}
          </script>
        </div>
      ) : showPlaceholder ? (
        <div class="w-full h-full rounded-2xl border border-dashed border-slate-200 bg-white/60 flex flex-col items-center justify-center">
          <div class="text-slate-400 font-semibold text-xs tracking-wider uppercase">Ad slot hidden</div>
          <div class="text-[10px] text-slate-400 mt-1">Dev placeholder</div>
        </div>
      ) : (
        // ✅ preserveSpace: 只保留高度（可选），视觉上完全不打扰
        <div class="w-full h-full" aria-hidden="true"></div>
      )}
    </div>
  </div>
) : null}