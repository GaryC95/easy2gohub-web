---
type Card = {
  label: string;
  desc: string;
  href: string;
  count: number;
  icon: string;
  iconClass?: string;
  themeClass: string;
  featuredTitle: string;
  featuredHref: string;
};

const { cards } = Astro.props as { cards: Card[] };
---

<section aria-label="Tool categories">
  <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-3">
    {cards.map((c) => (
      <a
        href={c.href}
        class={`relative overflow-hidden rounded-2xl p-4 text-white shadow-sm hover:brightness-105 transition ${c.themeClass}`}
      >
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-center gap-3 min-w-0">
            <div class="size-10 rounded-2xl bg-white/20 flex items-center justify-center shrink-0">
              <span class={`material-symbols-outlined text-white ${c.iconClass ?? ""}`}>{c.icon}</span>
            </div>
            <div class="min-w-0">
              <div class="font-semibold truncate">{c.label}</div>
              <div class="text-[11px] text-white/85 leading-snug line-clamp-2">
                {c.desc}
              </div>
            </div>
          </div>

          <div class="shrink-0 text-[11px] font-semibold px-2 py-1 rounded-full bg-white/20">
            {c.count}+ tools
          </div>
        </div>

        <div class="mt-3 rounded-xl bg-white/15 px-3 py-2 text-[11px] flex items-center justify-between gap-2">
          <span class="truncate">
            Featured: <span class="font-semibold">{c.featuredTitle}</span>
          </span>
          <span class="material-symbols-outlined text-base">chevron_right</span>
        </div>

        {/* 轻装饰 */}
        <div class="absolute -bottom-10 -right-10 size-24 rounded-full bg-white/10 blur-2xl"></div>
      </a>
    ))}
  </div>
</section>