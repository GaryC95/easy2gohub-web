---
const decor = [
  { icon: "photo", top: "10%", left: "8%", size: 42, rot: "-12deg" },
  { icon: "picture_as_pdf", top: "18%", left: "90%", size: 44, rot: "10deg" },
  { icon: "imagesmode", top: "26%", left: "72%", size: 40, rot: "-6deg" },
  { icon: "swap_horiz", top: "30%", left: "12%", size: 38, rot: "12deg" },
  { icon: "compress", top: "40%", left: "92%", size: 46, rot: "6deg" },
  { icon: "tune", top: "46%", left: "4%", size: 42, rot: "-10deg" },
  { icon: "bolt", top: "54%", left: "16%", size: 38, rot: "-8deg" },
  { icon: "lock", top: "58%", left: "86%", size: 44, rot: "8deg" },
  { icon: "auto_fix", top: "64%", left: "8%", size: 40, rot: "10deg" },
  { icon: "crop", top: "68%", left: "94%", size: 42, rot: "-12deg" },
  { icon: "text_fields", top: "76%", left: "78%", size: 36, rot: "10deg" },
  { icon: "description", top: "82%", left: "18%", size: 38, rot: "-10deg" },
  { icon: "find_replace", top: "22%", left: "52%", size: 36, rot: "8deg" },
  { icon: "file_present", top: "72%", left: "52%", size: 40, rot: "-6deg" },
  { icon: "grid_view", top: "34%", left: "84%", size: 34, rot: "8deg" },
  { icon: "shield", top: "14%", left: "64%", size: 34, rot: "-8deg" },
];

const keywordHints = [
  "image compressor",
  "jpg to png",
  "webp to png",
  "resize image",
  "heic to jpg",
];
---

<section class="glass tool-card p-6 md:p-8 relative overflow-hidden">
  {/* 背景装饰 */}
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    {decor.map((d) => (
      <span
        class="material-symbols-outlined absolute text-slate-900/10 select-none"
        style={`top:${d.top};left:${d.left};transform:rotate(${d.rot});font-size:${d.size}px;`}
      >
        {d.icon}
      </span>
    ))}
    <div class="absolute -top-24 -right-24 size-72 rounded-full bg-indigo-500/10 blur-3xl"></div>
    <div class="absolute -bottom-28 -left-24 size-72 rounded-full bg-sky-500/10 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 size-[520px] rounded-full bg-violet-500/5 blur-3xl"></div>
  </div>

  <div class="relative">
    <div class="mx-auto max-w-4xl text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-900/5 text-slate-700 text-xs font-semibold">
        <span class="material-symbols-outlined text-base">lock</span>
        Privacy-first • Runs locally • No uploads
      </div>

      <h1 class="mt-4 text-3xl md:text-5xl font-semibold text-slate-900 tracking-tight leading-[1.08]">
  Free Online Image Tools — Compress, Resize & Convert (No Uploads)
</h1>

      <p class="mt-3 text-slate-600 text-sm md:text-lg leading-relaxed">
  JPG to PNG, WebP to PNG, HEIC to JPG — run locally in your browser for fast, private results.
</p>

      {/* ✅ Hero Search（同步到 Header 的 #toolSearch，不改你的过滤逻辑） */}
      <div class="mt-6 mx-auto max-w-2xl">
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
            search
          </span>
          <input
            id="heroToolSearch"
            class="w-full bg-white/80 border border-slate-200 focus:ring-2 focus:ring-indigo-500/20 focus:bg-white transition-all rounded-2xl pl-12 pr-4 py-3.5 text-sm md:text-base shadow-sm"
            placeholder={`Search tools (e.g. ${keywordHints.join(", ")})`}
            type="text"
            autocomplete="off"
          />
        </div>
        <div class="mt-2 text-[11px] text-slate-500">
          Popular searches: <span class="font-semibold text-slate-600">{keywordHints.join(" • ")}</span>
        </div>

        <script type="module">
          const hero = document.getElementById("heroToolSearch");
          const header = document.getElementById("toolSearch");
          function sync() {
            if (!header || !hero) return;
            header.value = hero.value;
            header.dispatchEvent(new Event("input", { bubbles: true }));
          }
          hero?.addEventListener("input", sync);
        </script>
      </div>

      {/* ✅ 强化三特性：改成更有视觉重量的小卡 */}
      <div class="mt-6 grid sm:grid-cols-3 gap-3">
        <div class="rounded-2xl bg-white/70 border border-slate-200 p-4 flex items-start gap-3 text-left">
          <div class="size-10 rounded-2xl bg-indigo-500/10 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-indigo-600 text-base">offline_bolt</span>
          </div>
          <div>
            <div class="font-semibold text-slate-900 text-sm">Local processing</div>
            <div class="text-xs text-slate-600 mt-0.5">Your files stay on your device.</div>
          </div>
        </div>

        <div class="rounded-2xl bg-white/70 border border-slate-200 p-4 flex items-start gap-3 text-left">
          <div class="size-10 rounded-2xl bg-emerald-500/10 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-emerald-600 text-base">verified</span>
          </div>
          <div>
            <div class="font-semibold text-slate-900 text-sm">No signup needed</div>
            <div class="text-xs text-slate-600 mt-0.5">Open, use, download — done.</div>
          </div>
        </div>

        <div class="rounded-2xl bg-white/70 border border-slate-200 p-4 flex items-start gap-3 text-left">
          <div class="size-10 rounded-2xl bg-fuchsia-500/10 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-fuchsia-600 text-base">speed</span>
          </div>
          <div>
            <div class="font-semibold text-slate-900 text-sm">Fast workflows</div>
            <div class="text-xs text-slate-600 mt-0.5">Minimal clicks. Clean results.</div>
          </div>
        </div>
      </div>
    </div>

    {/* A1：下方模块 */}
    <div class="mt-6 space-y-5">
      <slot />
    </div>
  </div>
</section>