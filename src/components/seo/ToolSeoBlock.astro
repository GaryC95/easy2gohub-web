---
import AdsSlot from "../ads/AdsSlot.astro";
import { liveTools } from "@/data/tools";

type FaqItem = { q: string; a: string };

type ToolSeo = {
  intro?: string;
  tips?: string[];
  steps?: string[];
  howTo?: string[];
  faq?: FaqItem[];
  lastUpdated?: string;
  relatedTools?: string[];
};

type ToolLike = {
  category?: string;
  slug?: string;
  title?: string;
  description?: string;
  adsProfile?: "light" | "default" | "heavy" | "none";
  seo?: ToolSeo;
};

const {
  tool,
  seo: seoProp,
  showAds: showAdsProp,

  title,
  description,
  adsProfile: adsProfileProp,
  intro: introProp,
  tips: tipsProp,
  steps: stepsProp,
  howTo: howToProp,
  faq: faqProp,
} = Astro.props as {
  tool?: ToolLike;

  seo?: ToolSeo;
  showAds?: boolean;

  title?: string;
  description?: string;
  adsProfile?: "light" | "default" | "heavy" | "none";
  intro?: string;
  tips?: string[];
  steps?: string[];
  howTo?: string[];
  faq?: FaqItem[];
};

// -----------------------
// Helpers
// -----------------------
function isPlaceholder(s?: string) {
  const t = (s ?? "").trim();
  return !t || t === "..." || t === "…";
}

function cleanLines(arr?: string[]) {
  if (!Array.isArray(arr)) return [];
  return arr
    .map((x) => (x ?? "").trim())
    .filter((x) => x && !isPlaceholder(x));
}

function cleanFaq(arr?: FaqItem[]) {
  if (!Array.isArray(arr)) return [];
  return arr
    .map((it) => ({ q: (it?.q ?? "").trim(), a: (it?.a ?? "").trim() }))
    .filter((it) => it.q && it.a && !isPlaceholder(it.q) && !isPlaceholder(it.a));
}

// ✅ 默认 SEO fallback（当 tools.ts 里没写完整时兜底）
const DEFAULT_BY_SLUG: Record<string, ToolSeo> = {
  "image-compressor": {
    intro:
      "Free online image compressor that runs locally in your browser. Compress JPG, PNG, and WebP images with no uploads — fast, private, and easy to use.",
    steps: [
      "Add images by dragging them into the page or selecting them from your device.",
      "Choose output format and quality in the settings panel.",
      "Optional: reduce image dimensions to shrink file size further.",
      "Process your images and download each file or a ZIP for batch results.",
    ],
    tips: [
      "WebP usually gives smaller files for web use.",
      "JPG is best for photos; PNG is better for graphics or transparency.",
      "Downscaling large images can reduce file size much more than quality changes alone.",
    ],
    faq: [
      { q: "Are my images uploaded?", a: "No. Everything runs locally in your browser, so your files stay on your device." },
      { q: "Does it support batch compression?", a: "Yes. You can add multiple images and download the results as a ZIP." },
    ],
    relatedTools: ["image-resizer", "image-to-webp", "image-converter"],
  },

  "image-resizer": {
    intro:
      "Resize images online in your browser with no uploads. Change dimensions in batch for social media, websites, forms, and more.",
    steps: [
      "Add one or more images.",
      "Choose width, height, max edge, or percentage resize in Settings.",
      "Select the resize mode that fits your use case.",
      "Download resized images individually or as a ZIP.",
    ],
    tips: [
      "Keep aspect ratio enabled to avoid distortion.",
      "Avoid upscaling unless necessary, because it can make images look soft.",
      "After resizing, use Image Compressor to reduce file size even more.",
    ],
    faq: [
      { q: "Does this resize images in batch?", a: "Yes. You can resize multiple images at once." },
      { q: "Are my files uploaded?", a: "No. Everything runs locally in your browser." },
    ],
    relatedTools: ["image-compressor", "image-cropper", "image-to-webp"],
  },

  "image-converter": {
    intro:
      "Convert images between JPG, PNG, and WebP locally in your browser. No uploads, no signup, and fast results.",
    steps: [
      "Add images to the converter.",
      "Choose the target format in Settings.",
      "Optional: adjust quality for supported formats.",
      "Convert and download each file or a ZIP for batch conversion.",
    ],
    tips: [
      "Use PNG when you need transparency.",
      "Use JPG for smaller photo files.",
      "Use WebP when you want better web performance.",
    ],
    faq: [
      { q: "Which formats can I convert to?", a: "You can convert between common formats like JPG, PNG, and WebP." },
      { q: "Do you upload my images?", a: "No. Conversion happens locally in your browser." },
    ],
    relatedTools: ["image-to-jpg", "image-to-png", "image-to-webp"],
  },

  "image-to-webp": {
    intro:
      "Convert images to WebP online in your browser for smaller file sizes and faster loading websites. No uploads required.",
    steps: [
      "Add one or more images.",
      "Adjust output settings if needed.",
      "Convert to WebP.",
      "Download your results individually or as a ZIP.",
    ],
    tips: [
      "WebP usually works well for websites and modern browsers.",
      "WebP can preserve transparency, unlike JPG.",
    ],
    faq: [
      { q: "Why convert to WebP?", a: "WebP often gives smaller files while keeping good visual quality." },
      { q: "Does this tool upload files?", a: "No. Everything stays on your device." },
    ],
    relatedTools: ["image-converter", "image-compressor", "image-to-jpg"],
  },

  "image-to-jpg": {
    intro:
      "Convert images to JPG online in your browser for compatibility and smaller photo files. Private and no uploads.",
    steps: [
      "Add your images.",
      "Convert them to JPG.",
      "Download each result or use ZIP for multiple files.",
    ],
    tips: [
      "JPG is best for photos and general compatibility.",
      "JPG does not support transparency.",
    ],
    faq: [
      { q: "What happens to transparency?", a: "JPG does not support transparency, so transparent areas may be filled with a solid background." },
      { q: "Are files uploaded to a server?", a: "No. Conversion runs locally in your browser." },
    ],
    relatedTools: ["image-converter", "image-to-png", "image-compressor"],
  },

  "image-to-png": {
    intro:
      "Convert images to PNG online in your browser for lossless quality and transparency support. No uploads needed.",
    steps: [
      "Add your images.",
      "Convert them to PNG.",
      "Download each file or a ZIP for batch conversion.",
    ],
    tips: [
      "PNG is a good choice for graphics, logos, and transparency.",
      "PNG files can be larger than JPG for photos.",
    ],
    faq: [
      { q: "Is PNG always smaller?", a: "No. PNG is lossless and can be larger, especially for photographic images." },
      { q: "Does PNG support transparency?", a: "Yes. PNG supports transparency." },
    ],
    relatedTools: ["image-converter", "image-to-jpg", "image-compressor"],
  },

  "image-rotator": {
    intro:
      "Rotate or flip images online in your browser to fix orientation quickly and privately. Batch processing is supported.",
    steps: [
      "Add one or more images.",
      "Choose a rotation angle or flip option in Settings.",
      "Apply changes.",
      "Download the updated images individually or as a ZIP.",
    ],
    tips: [
      "Use 90° steps to correct sideways photos.",
      "Use horizontal flip to fix mirrored selfies or scans.",
    ],
    faq: [
      { q: "Can I rotate multiple images at once?", a: "Yes. Batch processing is supported." },
      { q: "Are my images uploaded?", a: "No. Everything runs locally in your browser." },
    ],
    relatedTools: ["image-cropper", "image-resizer", "image-converter"],
  },

  "image-cropper": {
    intro:
      "Crop images online with a draggable crop box that runs locally in your browser. Fast, private, and no uploads.",
    steps: [
      "Add an image to the cropper.",
      "Drag and resize the crop box to select the area you want.",
      "Apply the crop.",
      "Download the cropped image.",
    ],
    tips: [
      "Use a fixed aspect ratio for avatars, covers, thumbnails, and social media posts.",
      "For more precise results, crop first and resize afterward.",
    ],
    faq: [
      { q: "Are my images uploaded?", a: "No. Cropping happens locally in your browser." },
      { q: "Can I crop multiple images?", a: "You can process multiple images, but the workflow depends on the cropper UI and current tool behavior." },
    ],
    relatedTools: ["image-resizer", "image-compressor", "image-converter"],
  },
};

// -----------------------
// Resolve content
// -----------------------
const resolvedTitle = title ?? tool?.title ?? "Tool";
const resolvedDesc = description ?? tool?.description ?? "";
const seo = (seoProp ?? tool?.seo ?? {}) as ToolSeo;

const adsProfile = adsProfileProp ?? tool?.adsProfile ?? "default";
const showAds =
  typeof showAdsProp === "boolean" ? showAdsProp : adsProfile !== "none";

const slug = String(tool?.slug ?? "").trim();
const fallback = slug && DEFAULT_BY_SLUG[slug] ? DEFAULT_BY_SLUG[slug] : ({} as ToolSeo);

const introRaw = introProp ?? seo.intro ?? resolvedDesc ?? "";
const intro = isPlaceholder(introRaw)
  ? (fallback.intro ?? "This tool runs locally in your browser. No uploads. 100% private.")
  : introRaw;

const tips = cleanLines(
  Array.isArray(tipsProp) ? tipsProp :
  Array.isArray(seo.tips) ? seo.tips :
  fallback.tips
);

const steps = cleanLines(
  Array.isArray(stepsProp) ? stepsProp :
  Array.isArray(howToProp) ? howToProp :
  Array.isArray(seo.steps) ? seo.steps :
  Array.isArray(seo.howTo) ? seo.howTo :
  fallback.steps
);

const faq = cleanFaq(
  Array.isArray(faqProp) ? faqProp :
  Array.isArray(seo.faq) ? seo.faq :
  fallback.faq
);

const resolvedLastUpdated =
  !isPlaceholder(seo.lastUpdated) ? String(seo.lastUpdated).trim() :
  !isPlaceholder(fallback.lastUpdated) ? String(fallback.lastUpdated).trim() :
  "";

const relatedToolSlugs = Array.isArray(seo.relatedTools)
  ? seo.relatedTools
  : Array.isArray(fallback.relatedTools)
  ? fallback.relatedTools
  : [];

const relatedTools = liveTools.filter(
  (t) => relatedToolSlugs.includes(t.slug) && t.slug !== slug
);

// --- Ad density control ---
const showLightExtras = adsProfile === "light";
const showDefaultExtras = adsProfile === "default";
const showHeavyExtras = adsProfile === "heavy";

const showTopBanner = showAds && (showDefaultExtras || showHeavyExtras);
const showInContentBox = showAds && showHeavyExtras;
const showAfterFaqBanner = showAds && (showDefaultExtras || showHeavyExtras);

// -----------------------
// Structured data (JSON-LD)
// -----------------------
const faqJsonLd =
  faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faq.map((f) => ({
          "@type": "Question",
          name: f.q,
          acceptedAnswer: {
            "@type": "Answer",
            text: f.a,
          },
        })),
      }
    : null;

const howToJsonLd =
  steps.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "HowTo",
        name: `How to use ${resolvedTitle}`,
        description: intro,
        step: steps.map((s, i) => ({
          "@type": "HowToStep",
          position: i + 1,
          name: `Step ${i + 1}`,
          text: s,
        })),
      }
    : null;
---

<section class="mt-10 space-y-6">
  {howToJsonLd ? (
  <script
    type="application/ld+json"
    set:html={JSON.stringify(howToJsonLd)}
  />
) : null}

{faqJsonLd ? (
  <script
    type="application/ld+json"
    set:html={JSON.stringify(faqJsonLd)}
  />
) : null}

  <div class="glass tool-card p-8 space-y-6">
    <div class="flex items-start justify-between gap-6">
      <div class="min-w-0">
        <h2 class="text-2xl font-semibold text-slate-900">About {resolvedTitle}</h2>
        <p class="text-slate-600 mt-2 leading-relaxed">
          {intro}
        </p>

        {resolvedLastUpdated ? (
          <div class="mt-3 text-xs font-semibold uppercase tracking-wider text-slate-500">
            Last updated: {resolvedLastUpdated}
          </div>
        ) : null}
      </div>

      <div class="hidden md:flex shrink-0">
        <div class="px-4 py-2 rounded-full bg-indigo-500/10 text-indigo-700 font-semibold text-xs">
          How it works
        </div>
      </div>
    </div>

    {showTopBanner ? (
      <div class="pt-2">
        <AdsSlot label="SEO – Top Banner" variant="banner" height={120} className="w-full" />
      </div>
    ) : null}

    {steps.length > 0 ? (
      <div class="pt-1">
        <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider">How it works</h3>
        <ol class="mt-3 space-y-2 text-slate-600">
          {steps.map((s, i) => (
            <li class="flex gap-3">
              <span class="mt-0.5 size-6 rounded-full bg-indigo-500/10 text-indigo-700 flex items-center justify-center text-xs font-semibold shrink-0">
                {i + 1}
              </span>
              <span class="leading-relaxed">{s}</span>
            </li>
          ))}
        </ol>
      </div>
    ) : null}

    {showInContentBox ? (
      <div class="pt-4">
        <AdsSlot label="SEO – In-content Box" variant="box" height={240} className="w-full" />
      </div>
    ) : null}

    {tips.length > 0 ? (
      <div class="pt-1">
        <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider">Tips</h3>
        <ul class="mt-3 space-y-2 text-slate-600">
          {tips.map((t) => (
            <li class="flex gap-3">
              <span class="mt-1 size-2 rounded-full bg-fuchsia-500/60 shrink-0"></span>
              <span class="leading-relaxed">{t}</span>
            </li>
          ))}
        </ul>
      </div>
    ) : null}

    {faq.length > 0 ? (
      <div class="pt-1">
        <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider">FAQ</h3>

        <div class="mt-3 space-y-3">
          {faq.map((item) => (
            <details class="bg-white/70 border border-slate-200/70 rounded-2xl p-4">
              <summary class="cursor-pointer font-semibold text-slate-800">
                {item.q}
              </summary>
              <p class="mt-2 text-slate-600 leading-relaxed">
                {item.a}
              </p>
            </details>
          ))}
        </div>

        {showAfterFaqBanner ? (
          <div class="pt-6">
            <AdsSlot label="SEO – After FAQ Banner" variant="banner" height={120} className="w-full" />
          </div>
        ) : null}
      </div>
    ) : null}

    {relatedTools.length > 0 ? (
      <div class="pt-1">
        <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider">Related tools</h3>
        <div class="mt-3 flex flex-wrap gap-2">
          {relatedTools.map((t) => (
            <a
              href={`/${t.category}/${t.slug}/`}
              class="px-3 py-2 rounded-xl bg-white/70 border border-slate-200 text-sm font-semibold text-slate-700 hover:bg-white hover:text-slate-900 transition"
            >
              {t.title}
            </a>
          ))}
        </div>
      </div>
    ) : null}

    {showAds && showLightExtras ? (
      <div class="pt-2 text-xs text-slate-500 font-medium">
        Tip: Light ad profile keeps this section cleaner to improve reading experience.
      </div>
    ) : null}
  </div>
</section>