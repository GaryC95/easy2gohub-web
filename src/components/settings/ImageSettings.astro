---
import { getToolDef } from "../../lib/image/tool-registry.js";

// ✅ NEW: split parts
import SettingsHeader from "./imagesettings/SettingsHeader.astro";
import PrimaryActions from "./imagesettings/PrimaryActions.astro";
import ResizerGroup from "./imagesettings/ResizerGroup.astro";
import QualityRingGroup from "./imagesettings/QualityRingGroup.astro";
import OutputFormatGroup from "./imagesettings/OutputFormatGroup.astro";
import ResetGroup from "./imagesettings/ResetGroup.astro";
import RotateGroup from "./imagesettings/RotateGroup.astro";
import CropGroup from "./imagesettings/CropGroup.astro";

type Props = { slug?: string; title?: string };

const propsSlug = Astro.props.slug;
const slug =
  typeof propsSlug === "string" && propsSlug.trim()
    ? propsSlug.trim()
    : "unknown-tool";

let groups: string[] = [];
let mode: string = "transform";

try {
  const tool = getToolDef(slug);
  groups = tool.groups ?? [];
  mode = tool.mode ?? "transform";
} catch {
  groups = [];
  mode = "transform";
}
---

<aside
  class="glass-sidebar settings-panel rounded-2xl p-6 border border-slate-200/70"
  data-role="settings"
  data-tool={slug}
>
  <SettingsHeader mode={mode} />

    <div class="space-y-6">
    <div class="actions-bar" data-sticky-action>
      <PrimaryActions mode={mode} />
    </div>

    {groups.includes("crop") && (
      <section class="settings-group">
        <CropGroup slug={slug} />
      </section>
    )}

    {groups.includes("rotate") && (
      <section class="settings-group">
        <RotateGroup />
      </section>
    )}

    {slug === "image-resizer" && groups.includes("resize") && (
      <section class="settings-group">
        <ResizerGroup />
      </section>
    )}

    {mode !== "convert" && groups.includes("quality") && (
      <section class="settings-group">
        <QualityRingGroup />
      </section>
    )}

    {groups.includes("output") && (
      <section class="settings-group">
        <OutputFormatGroup mode={mode} />
      </section>
    )}

    <section class="settings-group">
      <ResetGroup />
    </section>
  </div>
</aside>

<script type="module" define:vars={{ slug, mode }}>
  const aside = document.querySelector(`[data-role="settings"][data-tool="${slug}"]`);
  if (!aside) console.warn("[ImageSettings] settings root not found for slug:", slug);

  const isResizer = slug === "image-resizer";
  const isConvert = mode === "convert";
  const isCompress = mode === "compress";

  const getApi = () => {
    const m = window.__imageTools;
    if (!m || typeof m.get !== "function") return null;
    return m.get(slug) || null;
  };

  const btnProcess = aside?.querySelector('[data-action="process"]');
  const btnZip = aside?.querySelector('[data-action="download-zip"]');
  const btnReturn = aside?.querySelector('[data-action="return-auto"]');

  const ring = aside?.querySelector('[data-role="quality-ring"]');
  const num = aside?.querySelector('[data-role="quality-number"]');

  const fmtWrap = aside?.querySelector('[data-role="fmt"]');
  const fmtSelect = aside?.querySelector('select[data-bind="settings.outputFormat"]');

  let inputMime = "";

  const setRing = (q) => {
    const v = Math.max(1, Math.min(100, Number(q) || 85));
    if (num) num.textContent = String(v);
    if (ring) {
      const dash = 502;
      const offset = dash - (dash * v) / 100;
      ring.setAttribute("stroke-dashoffset", String(offset));
    }
  };

  btnProcess?.addEventListener("click", async (e) => {
    e.preventDefault();
    const api = getApi();
    if (!api) return;
    await api.process?.();
  });

  btnZip?.addEventListener("click", async (e) => {
    e.preventDefault();
    const api = getApi();
    if (!api) return;
    await api.downloadZip?.();
  });

  btnReturn?.addEventListener("click", async (e) => {
    e.preventDefault();
    const api = getApi();
    if (!api) return;
    await api.returnToAutoBest?.();
  });

  const setFmtActive = (val) => {
    fmtWrap?.querySelectorAll("button[data-fmt]").forEach((b) => {
      const on = b.getAttribute("data-fmt") === val;
      b.classList.toggle("bg-[#137fec]", on);
      b.classList.toggle("text-white", on);
      b.classList.toggle("shadow-lg", on);
      b.classList.toggle("shadow-blue-500/20", on);
      b.classList.toggle("text-slate-600", !on);
      b.classList.toggle("bg-white/0", !on);
    });
  };

  const forceFmt = (v) => {
    if (!fmtSelect) return;
    fmtSelect.value = v;
    fmtSelect.dispatchEvent(new Event("input", { bubbles: true }));
    fmtSelect.dispatchEvent(new Event("change", { bubbles: true }));
    setFmtActive(v);
  };

  // ✅ compressor/resizer 的规则；converter 直接不做任何“压缩策略”
  const applyFormatRules = () => {
    if (isConvert) return;

    if (isResizer) {
      // resizer：keep only（你现在 UI 仍展示按钮，但可按需要禁用）
      return;
    }

    // compress：这里保留你原来的逻辑（如果你还有禁用/强制行为，可以在此恢复）
    // 目前简化：不强制
    return;
  };

  fmtWrap?.addEventListener("click", (e) => {
    const btn = e.target.closest("button[data-fmt]");
    if (!btn || !fmtSelect) return;
    if (btn.disabled) return;
    const v = btn.getAttribute("data-fmt");
    forceFmt(v);
  });

  if (fmtSelect) setFmtActive(fmtSelect.value || (isConvert ? "keep" : "webp"));

  aside?.addEventListener("image-settings:sync", (ev) => {
    const d = ev?.detail || {};

    if (d.key === "quality") setRing(d.value);
    if (d.key === "outputFormat") setFmtActive(d.value);

    if (d.key === "__zipEnabled" && btnZip) {
      btnZip.disabled = !d.value;
      btnZip.classList.toggle("opacity-50", !d.value);
      btnZip.classList.toggle("cursor-not-allowed", !d.value);
    }

    if (d.key === "__inputMime") {
      inputMime = String(d.value || "");
      applyFormatRules();
    }
  });

  const qRange = aside?.querySelector('input[data-bind="settings.quality"]');
  qRange?.addEventListener("input", () => setRing(qRange.value));
  qRange?.addEventListener("change", () => setRing(qRange.value));
  if (qRange) setRing(qRange.value);

  // ---------- Resizer UI ----------
  const setHidden = (bindKey, value) => {
    const el = aside?.querySelector(`[data-bind="settings.${bindKey}"]`);
    if (!el) return;

    if (el.type === "checkbox") el.checked = !!value;
    else el.value = value === undefined || value === null ? "" : String(value);

    el.dispatchEvent(new Event("input", { bubbles: true }));
    el.dispatchEvent(new Event("change", { bubbles: true }));
  };

  const setTabActive = (tab) => {
    const tabs = aside?.querySelector('[data-role="rz-tabs"]');
    const panels = aside?.querySelector('[data-role="rz-panels"]');
    if (!tabs || !panels) return;

    tabs.querySelectorAll("button[data-tab]").forEach((b) => {
      const on = b.getAttribute("data-tab") === tab;
      b.classList.toggle("bg-[#137fec]", on);
      b.classList.toggle("text-white", on);
      b.classList.toggle("shadow-lg", on);
      b.classList.toggle("shadow-blue-500/20", on);
      b.classList.toggle("text-slate-700", !on);
    });

    panels.querySelectorAll("[data-panel]").forEach((p) => {
      p.classList.toggle("hidden", p.getAttribute("data-panel") !== tab);
    });

    setHidden("resizeTab", tab);
  };

  const setModeActive = (m) => {
    const wrap = aside?.querySelector('[data-role="rz-mode"]');
    if (!wrap) return;
    wrap.querySelectorAll("button[data-mode]").forEach((b) => {
      const on = b.getAttribute("data-mode") === m;
      b.classList.toggle("bg-[#137fec]", on);
      b.classList.toggle("text-white", on);
      b.classList.toggle("shadow-lg", on);
      b.classList.toggle("shadow-blue-500/20", on);
      b.classList.toggle("text-slate-700", !on);
    });
    setHidden("resizeMode", m);
  };

  if (isResizer) {
    setTabActive("size");
    setModeActive("fit");

    aside?.querySelector('[data-role="rz-tabs"]')?.addEventListener("click", (e) => {
      const btn = e.target.closest("button[data-tab]");
      if (!btn) return;
      setTabActive(btn.getAttribute("data-tab"));
    });

    const w = aside?.querySelector('[data-role="rz-width"]');
    const h = aside?.querySelector('[data-role="rz-height"]');
    w?.addEventListener("input", () => setHidden("width", w.value ? Number(w.value) : undefined));
    h?.addEventListener("input", () => setHidden("height", h.value ? Number(h.value) : undefined));

    const keep = aside?.querySelector('[data-role="rz-keep"]');
    const up = aside?.querySelector('[data-role="rz-upscale"]');
    keep?.addEventListener("change", () => setHidden("keepAspect", !!keep.checked));
    up?.addEventListener("change", () => setHidden("allowUpscale", !!up.checked));

    aside?.querySelector('[data-role="rz-mode"]')?.addEventListener("click", (e) => {
      const btn = e.target.closest("button[data-mode]");
      if (!btn) return;
      const bg = aside?.querySelector('[data-role="rz-bgfill"]');
      if (bg?.checked) {
        setModeActive("fit");
        return;
      }
      setModeActive(btn.getAttribute("data-mode"));
    });

    const bgfill = aside?.querySelector('[data-role="rz-bgfill"]');
    const bgcolor = aside?.querySelector('[data-role="rz-bgcolor"]');
    bgfill?.addEventListener("change", () => {
      setHidden("backgroundFill", !!bgfill.checked);
      if (bgfill.checked) setModeActive("fit");
    });
    bgcolor?.addEventListener("input", () => setHidden("backgroundColor", bgcolor.value || "#ffffff"));

    const pct = aside?.querySelector('[data-role="rz-percent"]');
    const pctLabel = aside?.querySelector('[data-role="rz-percent-label"]');
    pct?.addEventListener("input", () => {
      const v = Number(pct.value || 50);
      if (pctLabel) pctLabel.textContent = `${v}%`;
      setHidden("scalePercent", v);
    });

    const keep2 = aside?.querySelector('[data-role="rz-keep2"]');
    const up2 = aside?.querySelector('[data-role="rz-upscale2"]');
    keep2?.addEventListener("change", () => setHidden("keepAspect", !!keep2.checked));
    up2?.addEventListener("change", () => setHidden("allowUpscale", !!up2.checked));

    aside?.querySelector('[data-panel="preset"]')?.addEventListener("click", (e) => {
      const btn = e.target.closest("button[data-preset]");
      if (!btn) return;
      const key = btn.getAttribute("data-preset");
      if (key === "1080x1080") {
        setHidden("width", 1080); setHidden("height", 1080);
        setHidden("keepAspect", true);
        setHidden("resizeMode", "fill");
      } else if (key === "1080x1920") {
        setHidden("width", 1080); setHidden("height", 1920);
        setHidden("keepAspect", true);
        setHidden("resizeMode", "fill");
      }
    });

    const bgfill3 = aside?.querySelector('[data-role="rz-bgfill3"]');
    const bgcolor3 = aside?.querySelector('[data-role="rz-bgcolor3"]');
    bgfill3?.addEventListener("change", () => {
      setHidden("backgroundFill", !!bgfill3.checked);
      if (bgfill3.checked) setHidden("resizeMode", "fit");
    });
    bgcolor3?.addEventListener("input", () => setHidden("backgroundColor", bgcolor3.value || "#ffffff"));
  }
</script>