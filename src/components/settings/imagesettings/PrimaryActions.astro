---
type Props = { mode: string };
const { mode } = Astro.props;
---

<button
  type="button"
  class="w-full py-4 rounded-2xl bg-[#137fec] text-white font-semibold shadow-lg shadow-blue-500/15 hover:brightness-110 active:scale-[0.99] transition"
  data-action="process"
>
  {mode === "convert" ? "Convert Image" : mode === "compress" ? "Compress Image" : "Apply Changes"}
</button>

<button
  type="button"
  class="w-full py-4 rounded-2xl bg-white/60 text-slate-400 font-semibold border border-slate-200/70 opacity-50 cursor-not-allowed"
  data-action="download-zip"
  disabled
>
  Download ZIP
</button>