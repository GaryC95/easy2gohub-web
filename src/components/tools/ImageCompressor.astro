---
import DropZone from "../core/DropZone.astro";
const slug = "image-compressor";
---

<section class="tool-root space-y-6 min-w-0" data-tool-root={slug}>
  <!-- Dropzone -->
  <div class="min-w-0">
    <DropZone
      dzId={slug}
      accept="image/*"
      multiple={true}
      label="Drop images here"
      hint="Local processing • Auto-first • Batch supported"
      fixedStage={true}
      stageMode="square"
      stageMax={1024}
    />
  </div>

  <!-- stats row -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 min-w-0">
    <div class="glass tool-card rounded-2xl p-5 h-24 flex flex-col justify-between">
      <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-widest">Original File</span>
      <div class="text-2xl font-extrabold text-slate-900 leading-none tabular-nums" data-role="stat-orig">—</div>
    </div>

    <div class="glass tool-card rounded-2xl p-5 h-24 flex flex-col justify-between">
      <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-widest">Compressed Size</span>
      <div class="text-2xl font-extrabold text-slate-900 leading-none tabular-nums" data-role="stat-out">—</div>
    </div>

    <div class="rounded-2xl p-5 h-24 flex flex-col justify-between bg-[#137fec] shadow-[0_18px_50px_rgba(19,127,236,0.22)]">
      <span class="block text-[10px] uppercase font-bold text-white/80 tracking-widest">Space Saved</span>
      <div class="text-2xl md:text-3xl font-black text-white leading-none tabular-nums" data-role="stat-saved">—</div>
    </div>

    <div class="glass tool-card rounded-2xl p-5 h-24 flex flex-col justify-between">
      <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-widest">Processing Time</span>
      <div class="text-2xl font-extrabold text-emerald-700 leading-none tabular-nums" data-role="stat-time">—</div>
    </div>
  </div>

  <!-- results -->
  <section class="glass tool-card rounded-2xl p-5">
    <div class="flex items-center justify-between mb-3">
      <div class="font-extrabold text-slate-900">Results</div>
      <div class="text-sm text-slate-500">Per-file download • ZIP from right panel</div>
    </div>
    <div class="space-y-3" data-role="result-list"></div>
  </section>
</section>