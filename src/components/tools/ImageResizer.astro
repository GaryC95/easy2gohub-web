---
// src/components/tools/ImageResizer.astro
import DropZone from "../core/DropZone.astro";
const slug = "image-resizer";
---

<section class="tool-root space-y-6" data-tool-root={slug}>
  <!-- slider mounts into dropzone stage -->
  <DropZone
    dzId={slug}
    accept="image/*"
    multiple={true}
    label="Drop images here"
    hint="Local processing • Resize-first • Batch supported"
    fixedStage={true}
  stageMode="square"
  stageMax={1024}
  />

  <!-- stats row -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="glass tool-card rounded-2xl p-5">
      <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-widest mb-2">Original File</span>
      <div class="text-2xl font-extrabold text-slate-900" data-role="stat-orig">—</div>
    </div>

    <div class="glass tool-card rounded-2xl p-5">
      <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-widest mb-2">Output Size</span>
      <div class="text-2xl font-extrabold text-slate-900" data-role="stat-out">—</div>
    </div>

    <div class="rounded-2xl p-5 bg-[#137fec] shadow-[0_18px_50px_rgba(19,127,236,0.22)]">
      <span class="block text-[10px] uppercase font-bold text-white/80 tracking-widest mb-2">Change</span>
      <div class="text-3xl font-black text-white" data-role="stat-saved">—</div>
    </div>

    <div class="glass tool-card rounded-2xl p-5">
      <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-widest mb-2">Processing Time</span>
      <div class="text-2xl font-extrabold text-emerald-700" data-role="stat-time">—</div>
    </div>
  </div>

  <!-- results -->
  <section class="glass tool-card rounded-2xl p-5">
    <div class="flex items-center justify-between mb-3">
      <div class="font-extrabold text-slate-900">Results</div>
      <div class="text-sm text-slate-500">Per-file download • ZIP from right panel</div>
    </div>
    <div class="space-y-3" data-role="result-list"></div>
  </section>
</section>
