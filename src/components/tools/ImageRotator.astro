---
// src/components/tools/ImageRotator.astro
import DropZone from "../core/DropZone.astro";
const slug = "image-rotator";
---

<section class="tool-root space-y-6 min-w-0" data-tool-root={slug}>
  <DropZone
    dzId={slug}
    accept="image/*"
    multiple={true}
    label="Drop images here"
    hint="Local processing • Rotate / Flip • Batch supported"
    fixedStage={true}
  />

  <div class="glass tool-card rounded-2xl p-5 text-sm text-slate-600">
    Tip: Use the right panel to choose rotation angle and flip options, then click <b>Apply Changes</b>.
  </div>

  <section class="glass tool-card rounded-2xl p-5">
    <div class="flex items-center justify-between mb-3">
      <div class="font-extrabold text-slate-900">Results</div>
      <div class="text-sm text-slate-500">Per-file download • ZIP from right panel</div>
    </div>

    <div class="space-y-3" data-role="result-list"></div>
  </section>
</section>

<script is:inline type="module">
(() => {
  const root = document.querySelector('[data-tool-root="image-rotator"]');
  if (!root) return;

  const hideBadges = () => {
    const slider = root.querySelector(".comparison-slider");
    if (!slider) return;

    // 只隐藏两个角落 badge，不碰 canvas
    const badges = slider.querySelectorAll(".glass, .bg-\\[\\#137fec\\]");
    badges.forEach((b) => {
      const t = (b.textContent || "").trim().toLowerCase();
      if (t === "original" || t === "preview") b.style.display = "none";
    });
  };

  hideBadges();
  root.addEventListener("dropzone:change", () => queueMicrotask(hideBadges));

  const mo = new MutationObserver(hideBadges);
  mo.observe(root, { childList: true, subtree: true });
})();
</script>