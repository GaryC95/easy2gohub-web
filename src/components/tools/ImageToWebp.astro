---
// src/components/tools/ImageToWebp.astro
import DropZone from "../core/DropZone.astro";
const slug = "image-to-webp";
---

<section class="tool-root space-y-6 min-w-0" data-tool-root={slug}>
  <DropZone
    dzId={slug}
    accept="image/*"
    multiple={true}
    label="Drop images here"
    hint="Local processing • Convert to WebP • Batch supported"
    fixedStage={true}
      stageMode="square"
      stageMax={1024}
  />

  <!-- stats row (same as converter) -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="glass tool-card rounded-2xl p-5">
      <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-widest mb-2">Original Format</span>
      <div class="text-2xl font-extrabold text-slate-900" data-role="stat-orig">—</div>
    </div>

    <div class="glass tool-card rounded-2xl p-5">
      <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-widest mb-2">Output Format</span>
      <div class="text-2xl font-extrabold text-slate-900" data-role="stat-out">—</div>
    </div>

    <div class="rounded-2xl p-5 bg-[#137fec] shadow-[0_18px_50px_rgba(19,127,236,0.22)]">
      <span class="block text-[10px] uppercase font-bold text-white/80 tracking-widest mb-2">Files</span>
      <div class="text-3xl font-black text-white" data-role="stat-saved">—</div>
    </div>

    <div class="glass tool-card rounded-2xl p-5">
      <span class="block text-[10px] uppercase font-bold text-slate-500 tracking-widest mb-2">Processing Time</span>
      <div class="text-2xl font-extrabold text-emerald-700" data-role="stat-time">—</div>
    </div>
  </div>

  <!-- results -->
  <section class="glass tool-card rounded-2xl p-5">
    <div class="flex items-center justify-between mb-3">
      <div class="font-extrabold text-slate-900">Results</div>
      <div class="text-sm text-slate-500">Per-file download • ZIP from right panel</div>
    </div>
    <div class="space-y-3" data-role="result-list"></div>
  </section>
</section>

<style is:global>
  /* ✅ only for image-to-webp */

  /* 1) Hide Reset block (Return to Best Auto) */
  [data-role="settings"][data-tool="image-to-webp"] [data-role="reset"] {
    display: none !important;
  }

  /* 2) Keep only WEBP button */
  [data-role="settings"][data-tool="image-to-webp"] [data-role="fmt"] {
    grid-template-columns: 1fr !important;
  }
  [data-role="settings"][data-tool="image-to-webp"] [data-role="fmt"] button[data-fmt]:not([data-fmt="webp"]) {
    display: none !important;
  }
  [data-role="settings"][data-tool="image-to-webp"] [data-role="fmt"] button[data-fmt="webp"] {
    pointer-events: none;
  }

  /* 3) No tips/hints */
  [data-role="settings"][data-tool="image-to-webp"] [data-role="fmt-tip"],
  [data-role="settings"][data-tool="image-to-webp"] [data-role="fmt-hint"] {
    display: none !important;
  }
</style>

<script is:inline type="module">
  (() => {
    const SLUG = "image-to-webp";
    const FIXED = "webp";

    const toolRoot = document.querySelector(`[data-tool-root="${SLUG}"]`);
    const statOut = toolRoot?.querySelector('[data-role="stat-out"]');

    const setStatOut = (v) => {
      if (!statOut) return;
      statOut.textContent = v;
    };

    const boot = (retry = 80) => {
      const settingsRoot = document.querySelector(`[data-role="settings"][data-tool="${SLUG}"]`);
      if (!settingsRoot) {
        if (retry > 0) return setTimeout(() => boot(retry - 1), 50);
        return;
      }

      const sel = settingsRoot.querySelector('select[data-bind="settings.outputFormat"]');

      const lockToWebp = () => {
        if (!sel) return;
        if (sel.value !== FIXED) {
          sel.value = FIXED;
          sel.dispatchEvent(new Event("input", { bubbles: true }));
          sel.dispatchEvent(new Event("change", { bubbles: true }));
        }
      };

      // initial lock
      lockToWebp();

      // keep locked when engine syncs
      settingsRoot.addEventListener("image-settings:sync", (ev) => {
        const d = ev?.detail || {};
        if (d.key === "outputFormat" || d.key === "__inputMime") {
          lockToWebp();
          // avoid confusion: always show WEBP as output format
          queueMicrotask(() => setStatOut("WEBP"));
        }
      });

      // on file change: force WEBP display
      toolRoot?.addEventListener("dropzone:change", () => {
        lockToWebp();
        queueMicrotask(() => setStatOut("WEBP"));
      });

      // on clear
      toolRoot?.addEventListener("dropzone:clear", () => {
        setStatOut("—");
      });

      // safety: if some other code overwrites stat-out
      if (statOut) {
        const mo = new MutationObserver(() => {
          const txt = (statOut.textContent || "").trim();
          if (txt && txt !== "—" && txt !== "WEBP") setStatOut("WEBP");
        });
        mo.observe(statOut, { childList: true, characterData: true, subtree: true });
      }
    };

    boot();
  })();
</script>