---
import "../styles/global.css";
import uiBridgeUrl from "../lib/image/image-ui-bridge.js?url";

const {
  title = "Easy2GoHub – Free Image Tools (Fast & Private)",
  description = "Free online image tools for compression, resizing, and format conversion. Fast, private, and processed locally in your browser.",
  canonical,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    {canonical ? <link rel="canonical" href={canonical} /> : null}
    <link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/manifest.json">

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
    />

    <style>
      .material-symbols-outlined,
      .material-symbols-rounded {
        font-variation-settings: "FILL" 0, "wght" 500, "GRAD" 0, "opsz" 24;
        line-height: 1;
        font-family: "Material Symbols Outlined";
        font-weight: normal;
        font-style: normal;
        display: inline-block;
        white-space: nowrap;
        direction: ltr;
        -webkit-font-feature-settings: "liga";
        -webkit-font-smoothing: antialiased;
      }
      .material-symbols-rounded {
        font-family: "Material Symbols Rounded";
      }
    </style>
    {import.meta.env.PROD ? (
  <>
    <meta name="google-adsense-account" content="ca-pub-1409463603356964" />
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1409463603356964"
      crossorigin="anonymous"
    ></script>
  </>
) : null}
  </head>

  <body class="min-h-screen text-slate-900">
    <slot />

    <!-- Toast Root -->
    <div
      data-role="ui-toast-root"
      class="fixed right-4 top-4 z-[80] flex flex-col gap-3 pointer-events-none"
    ></div>

    <!-- Modal -->
    <div
      data-role="ui-modal"
      class="hidden fixed inset-0 z-[90] items-center justify-center"
    >
      <div data-role="ui-modal-backdrop" class="absolute inset-0 bg-black/40"></div>

      <div class="relative w-[92vw] max-w-lg rounded-3xl border border-slate-200 bg-white/90 backdrop-blur p-6 shadow-2xl">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0">
            <div data-role="ui-modal-title" class="text-lg font-bold text-slate-900">Notice</div>
            <div data-role="ui-modal-msg" class="mt-2 text-sm leading-relaxed text-slate-600">
              ...
            </div>
          </div>
          <button
            class="w-10 h-10 rounded-xl bg-slate-900/5 hover:bg-slate-900/10 border border-slate-200 flex items-center justify-center"
            onclick="this.closest('[data-role=ui-modal]').classList.add('hidden'); this.closest('[data-role=ui-modal]').classList.remove('flex')"
          >
            <span class="material-symbols-outlined text-slate-700">close</span>
          </button>
        </div>

        <div class="mt-6 flex gap-3 justify-end">
          <button
            data-role="ui-modal-secondary"
            class="hidden px-4 py-2 rounded-xl border border-slate-200 bg-slate-900/5 hover:bg-slate-900/10 text-sm font-bold text-slate-700"
          >
            Secondary
          </button>
          <button
            data-role="ui-modal-primary"
            class="px-4 py-2 rounded-xl bg-[#137fec] hover:brightness-110 text-sm font-bold text-white shadow-lg shadow-[#137fec]/20"
          >
            OK
          </button>
        </div>
      </div>
    </div>

    <!-- UI Bridge script -->
    <script type="module" src={uiBridgeUrl}></script>

  <footer class="border-t border-slate-200/80 bg-white/40 backdrop-blur">
      <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col md:flex-row gap-4 items-center justify-between text-xs text-slate-500">
        <div class="font-semibold">© {new Date().getFullYear()} Easy2GoHub</div>
        <nav class="flex items-center gap-4 font-semibold">
          <a href="/about/" class="hover:text-slate-700">About</a>
          <a href="/privacy-policy/" class="hover:text-slate-700">Privacy Policy</a>
          <a href="/terms/" class="hover:text-slate-700">Terms</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
