---
import BaseLayout from "./BaseLayout.astro";
import AppSidebar from "../components/ui/AppSidebar.astro";
import AdsSlot from "../components/ads/AdsSlot.astro";
import StickyAd from "../components/ads/StickyAd.astro";

const {
  title,
  description,
  canonical,
  adsProfile = "light",
} = Astro.props;

const showAds = adsProfile !== "none";
const showTop = showAds && (adsProfile === "default" || adsProfile === "heavy");
const showBottom = showAds; // light/default/heavy 都给一个底部补位
---

<BaseLayout title={title} description={description} canonical={canonical}>
  

  <div class="min-h-screen">
    <div class="flex">
      <div class="hidden md:block">
        <AppSidebar />
      </div>

      <main class="flex-1 min-w-0 relative bg-gradient-to-br from-slate-50 via-indigo-50/35 to-fuchsia-50/25">
      {/* ✅ Global background (Hero-like) for the whole main area */}
<div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
  <div class="absolute -top-24 -right-24 size-[560px] rounded-full bg-indigo-500/10 blur-3xl"></div>
  <div class="absolute -bottom-28 -left-24 size-[560px] rounded-full bg-sky-500/10 blur-3xl"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 size-[720px] rounded-full bg-violet-500/5 blur-3xl"></div>

  {/* optional subtle texture */}
  <div class="absolute inset-0 opacity-[0.25] [background:radial-gradient(circle_at_20%_20%,rgba(2,6,23,0.04)_0,transparent_45%),radial-gradient(circle_at_80%_30%,rgba(2,6,23,0.03)_0,transparent_45%),radial-gradient(circle_at_50%_80%,rgba(2,6,23,0.03)_0,transparent_50%)]"></div>
</div>
        <header class="h-16 border-b border-slate-200/80 bg-white/50 backdrop-blur-md px-6 md:px-8 flex items-center justify-between">
          <div class="flex items-center gap-3 min-w-0">
            <span class="material-symbols-outlined text-slate-500">arrow_back</span>
            <h1 class="text-base font-semibold text-slate-900 truncate">{title}</h1>
          </div>

          <div class="hidden md:flex items-center gap-3">
            <a
              href="/tools/"
              class="px-4 py-2 rounded-xl bg-[#137fec] text-white text-sm font-semibold shadow-lg shadow-blue-500/15 hover:brightness-110 transition"
            >
              All Tools
            </a>
          </div>
        </header>

        {/* ✅ Top Banner: visible, not intrusive */}
        {showTop ? (
          <div class="px-6 md:px-8 pt-6 max-w-[1200px] mx-auto w-full">
            <div class="hidden md:block">
              <AdsSlot label="Top Banner" variant="banner" height={120} className="w-full" />
            </div>
            <div class="md:hidden">
              <AdsSlot label="Top Banner" variant="banner" height={100} className="w-full" />
            </div>
          </div>
        ) : null}

        <div class="p-6 md:p-8 max-w-[1200px] mx-auto w-full">
          <slot />

          {/* ✅ Bottom Box: end-of-page monetization, low distraction */}
          {showBottom ? (
            <div class="mt-10">
              <AdsSlot label="Bottom Box" variant="box" height={220} className="w-full" />
            </div>
          ) : null}
        </div>
      </main>
      {showAds && (adsProfile === "default" || adsProfile === "heavy") ? (
  <StickyAd label="Sticky" />
) : null}

    </div>
  </div>
</BaseLayout>
