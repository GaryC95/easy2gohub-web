---
// src/layouts/ToolLayout.astro
import BaseLayout from "./BaseLayout.astro";
import AppSidebar from "../components/ui/AppSidebar.astro";
import AdsSlot from "../components/ads/AdsSlot.astro";
import StickyAd from "../components/ads/StickyAd.astro";

const {
  title,
  description,
  canonical,
  adsProfile = "default",
  toolSlug = "",
} = Astro.props;

const showAds = adsProfile !== "none";
const isToolPage = !!toolSlug;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <div class="min-h-screen bg-slate-50">
    <div class="flex">
      <div class="hidden md:block">
        <AppSidebar />
      </div>

      <main class="flex-1 min-w-0 relative bg-gradient-to-br from-slate-50 via-indigo-100/60 to-fuchsia-100/45">
        {/* ✅ background blobs */}
        <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
          <div class="absolute -top-24 -right-24 size-[560px] rounded-full bg-indigo-500/18 blur-3xl"></div>
          <div class="absolute -bottom-28 -left-24 size-[560px] rounded-full bg-sky-500/18 blur-3xl"></div>
        </div>

        <header class="h-16 border-b border-slate-200 bg-white/70 backdrop-blur-md px-4 md:px-8 flex items-center justify-between">
          <div class="flex items-center gap-3 min-w-0">
            {/* ✅ Back button */}
            <button
              type="button"
              class="inline-flex items-center justify-center size-9 rounded-xl hover:bg-slate-100/80 active:scale-[0.99] transition"
              aria-label="Back"
              data-action="tool-back"
            >
              <span class="material-symbols-outlined text-slate-600">arrow_back</span>
            </button>

            <h1 class="text-lg font-bold truncate text-slate-900">{title}</h1>

            <span class="hidden sm:inline-flex text-[10px] bg-emerald-500/10 text-emerald-700 px-2 py-0.5 rounded-full font-bold uppercase tracking-wider">
              Active Workspace
            </span>
          </div>

          <div class="flex items-center gap-2">
            {/* ✅ mobile: Controls button (only on tool page) */}
            {isToolPage ? (
              <button
                type="button"
                class="lg:hidden px-3 py-2 rounded-xl bg-white/70 border border-slate-200/70 text-slate-700 text-sm font-bold hover:bg-white transition"
                data-action="open-controls"
              >
                Controls
              </button>
            ) : null}

            <a
              href="/tools/"
              class="px-4 py-2 rounded-xl bg-[#137fec] text-white text-sm font-bold shadow-lg shadow-blue-500/20"
            >
              All Tools
            </a>
          </div>
        </header>

        <div class="p-4 md:p-8 max-w-[1440px] mx-auto w-full">
          <div data-tool-scope={toolSlug || ""}>
            <div class={isToolPage ? "tool-grid" : "grid grid-cols-1"}>
              {/* LEFT */}
              <div class={`space-y-6 min-w-0 ${isToolPage ? "" : "max-w-[1100px] mx-auto"}`}>
                <slot />
                <slot name="below-main" />

                {showAds && (
                  <slot name="ads-below-tool">
                    <AdsSlot label="Sponsored" height="h-40" />
                  </slot>
                )}
              </div>

              {/* RIGHT (IMPORTANT): render on ALL breakpoints, but as drawer on mobile) */}
              {isToolPage ? (
                <aside class="min-w-0 tool-controls-panel" aria-label="Tool controls">
                  <div class="lg:sticky lg:top-24 tool-panel-h overflow-visible">
                    <div class="h-full space-y-6">
                      <slot name="tool-settings" />
                      <slot name="right-rail" />
                      {showAds && (
                        <slot name="ads-right-rail">
                          <AdsSlot label="Sponsored" height="h-56" />
                        </slot>
                      )}
                    </div>
                  </div>
                </aside>
              ) : null}
            </div>
          </div>
        </div>

        {/* ✅ mobile drawer backdrop */}
        {isToolPage ? (
          <div class="lg:hidden fixed inset-0 z-[55] bg-black/30 hidden" data-role="controls-backdrop"></div>
        ) : null}
      </main>

      {showAds && (adsProfile === "default" || adsProfile === "heavy") ? (
        <StickyAd label="Sticky" />
      ) : null}
    </div>
  </div>

  {/* ✅ IMPORTANT: tool-boot.js is in src/lib/... so import as module */}
  <script type="module" src="/lib/image/tool-boot.js"></script>

  {/* ✅ Back + Drawer wiring (NO illegal top-level return) */}
  <script is:inline>
  (() => {
    // Back
    const backBtn = document.querySelector('[data-action="tool-back"]');
    if (backBtn) {
      backBtn.addEventListener('click', () => {
        try {
          if (window.history.length > 1) window.history.back();
          else window.location.href = '/tools/';
        } catch {
          window.location.href = '/tools/';
        }
      });
    }

    // Drawer
    const openBtn = document.querySelector('[data-action="open-controls"]');
    const panel = document.querySelector('.tool-controls-panel');
    const backdrop = document.querySelector('[data-role="controls-backdrop"]');

    if (!openBtn || !panel || !backdrop) return;

    const open = () => {
      document.documentElement.classList.add('tool-controls-open');
      backdrop.classList.remove('hidden');
    };
    const close = () => {
      document.documentElement.classList.remove('tool-controls-open');
      backdrop.classList.add('hidden');
    };

    openBtn.addEventListener('click', open);
    backdrop.addEventListener('click', close);
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  })();
  </script>

  {/* ✅ mobile drawer CSS (does NOT affect desktop logic) */}
  <style is:global>
    /* Desktop: behave like normal right column */
    .tool-controls-panel {
      display: block;
    }

    /* Mobile: drawer */
    @media (max-width: 1023px) {
      .tool-controls-panel {
        position: fixed;
        left: 12px;
        right: 12px;
        bottom: 12px;
        z-index: 56;

        max-height: 78vh;
        overflow: auto;

        transform: translateY(115%);
        transition: transform 180ms ease;

        border-radius: 24px;
      }

      /* drawer open */
      html.tool-controls-open .tool-controls-panel {
        transform: translateY(0);
      }

      /* make the sidebar card look nice in drawer */
      .tool-controls-panel > div {
        border-radius: 24px;
      }
    }
  </style>
</BaseLayout>