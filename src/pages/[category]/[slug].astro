---
 // src/pages/[category]/[slug].astro
import ToolLayout from "@/layouts/ToolLayout.astro";
import ToolSeoBlock from "@/components/seo/ToolSeoBlock.astro";
import { tools } from "@/data/tools";

// ===== Tool components =====
import ImageCompressor from "@/components/tools/ImageCompressor.astro";
import ImageResizer from "@/components/tools/ImageResizer.astro";
import ImageConverter from "@/components/tools/ImageConverter.astro";
import ImageToWebp from "@/components/tools/ImageToWebp.astro";
import ImageToJpg from "@/components/tools/ImageToJpg.astro";
import ImageToPng from "@/components/tools/ImageToPng.astro";
import ImageRotator from "@/components/tools/ImageRotator.astro";
import ImageWatermark from "@/components/tools/ImageWatermark.astro";
import FaviconGenerator from "@/components/tools/FaviconGenerator.astro";
import ExifTool from "@/components/tools/ExifTool.astro";
import ImageBorder from "@/components/tools/ImageBorder.astro";
import MemeGenerator from "@/components/tools/MemeGenerator.astro";
import ImageCropper from "@/components/tools/ImageCropper.astro";

import ToolPlaceholder from "@/components/tools/ToolPlaceholder.astro";

// ===== Settings components =====
import ImageSettings from "@/components/settings/ImageSettings.astro";

// ===== Component Maps =====
const TOOL_COMPONENTS: Record<string, any> = {
  "image-compressor": ImageCompressor,
  "image-resizer": ImageResizer,
  "image-converter": ImageConverter,
  "image-to-webp": ImageToWebp,
  "image-to-jpg": ImageToJpg,
  "image-to-png": ImageToPng,
  "image-rotator": ImageRotator,
  "image-watermark": ImageWatermark,
  "favicon-generator": FaviconGenerator,
  "exif-tool": ExifTool,
  "image-border": ImageBorder,
  "meme-generator": MemeGenerator,
  "image-cropper": ImageCropper,
};

// 你现在 settingsType= "image" 才会走 ImageSettings
const SETTINGS_COMPONENTS: Record<string, any> = {
  image: ImageSettings,
};

export async function getStaticPaths() {
  return tools.map((t) => ({
    params: { category: t.category, slug: t.slug },
  }));
}

const { category, slug } = Astro.params;
const tool = tools.find((t) => t.category === category && t.slug === slug);
if (!tool) throw new Error("Tool not found");

const ToolComponent = TOOL_COMPONENTS[tool.slug] ?? ToolPlaceholder;

const settingsType = tool.settingsType ?? "none";
const SettingsComponent =
  settingsType !== "none" ? (SETTINGS_COMPONENTS[settingsType] ?? null) : null;

const canonical = `https://www.easy2gohub.com/${tool.category}/${tool.slug}/`;
const adsProfile = tool.adsProfile ?? "default";
---

<!-- ✅ toolSlug 传给 ToolLayout -->
<ToolLayout
  title={tool.title}
  description={tool.description}
  canonical={canonical}
  adsProfile={adsProfile}
  toolSlug={tool.slug}
>
  <ToolComponent tool={tool} />

  {SettingsComponent ? (
    <div slot="tool-settings">
      <SettingsComponent slug={tool.slug} title={`${tool.title} Settings`} />
    </div>
  ) : null}

  <ToolSeoBlock title={tool.title} seo={tool.seo} adsProfile={adsProfile} showAds={adsProfile !== "none"} />
</ToolLayout>