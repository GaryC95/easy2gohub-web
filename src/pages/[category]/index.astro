---
import ToolLayout from "../../layouts/ToolLayout.astro";
import ToolGrid from "../../components/ToolGrid.astro";
import { CATEGORY_META, getToolsByCategory, getActiveCategories } from "../../data/tools";

// ✅ SSG: generate all category pages at build time
export async function getStaticPaths() {
  return getActiveCategories().map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;

const cat = String(category || "").toLowerCase();
const meta = (CATEGORY_META as any)[cat];

if (!meta) {
  throw new Error(`Unknown category: ${cat}`);
}

const list = getToolsByCategory(cat);

const title = `${meta.label} Tools – Free, Private, No Uploads | Easy2GoHub`;
const description = meta.desc || `Browse ${meta.label} tools on Easy2GoHub.`;
const canonical = ` https://easy2gohub.com/${cat}/`;
---

<ToolLayout
  title={title}
  headerTitle={`${meta.label} Tools`}
  description={description}
  canonical={canonical}
  adsProfile="light"
>
  <section class="space-y-6">
    <div class="glass tool-card p-8 text-center bg-gradient-to-br from-violet-50/80 via-indigo-50/55 to-white/40 border border-slate-200/70">
  <div class="flex justify-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/70 border border-slate-200 text-slate-700 text-xs font-semibold">
      <span class={`material-symbols-outlined ${meta.iconClass}`}>{meta.icon}</span>
      {meta.label}
    </div>
  </div>

  <h1 class="mt-4 text-3xl md:text-4xl font-semibold text-slate-900 tracking-tight">
    {meta.label} tools
  </h1>

  <p class="mt-3 text-slate-700 max-w-2xl mx-auto leading-relaxed">
    {meta.desc}
  </p>

  <div class="mt-4 text-xs font-semibold text-slate-700 uppercase tracking-wider">
    {list.length} tools
  </div>
</div>
    

    <ToolGrid tools={list} />
  </section>
</ToolLayout>