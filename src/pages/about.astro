---
import ToolLayout from "../layouts/ToolLayout.astro";

const title = "About";
const description =
  "About Easy2GoHub: privacy-first image tools that run locally in your browser (no uploads by default).";
const canonical = " https://easy2gohub.com/about/";
---

<ToolLayout title={title} description={description} canonical={canonical} adsProfile="none">
  <section class="tool-card p-10 space-y-6">
    <h1 class="text-3xl font-semibold text-slate-900 text-center">About Easy2GoHub</h1>

    <p class="text-slate-700 leading-relaxed max-w-3xl mx-auto">
      Easy2GoHub is a collection of simple, fast, privacy-first tools designed to help you complete everyday tasks directly
      in your browser.
    </p>

    <div class="space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">What Easy2GoHub Does</h2>
      <p class="text-slate-700 leading-relaxed">
        Right now, Easy2GoHub focuses on image tools — compressing, resizing, converting formats, cropping, and basic edits.
        More categories (PDF, files, and text utilities) may be added later.
      </p>
    </div>

    <div class="space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">Privacy First</h2>
      <p class="text-slate-700 leading-relaxed">
        Our goal is to keep your files on your device. Most tools run locally in your browser, which means your images are
        processed without being uploaded to our servers by default.
      </p>
      <p class="text-slate-700 leading-relaxed">
        If a future tool requires uploading files, that will be clearly disclosed on the tool page before you use it.
      </p>
    </div>

    <div class="space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">Contact</h2>
      <p class="text-slate-700 leading-relaxed">
        Questions, feedback, or suggestions?
        Email us at <span class="font-semibold text-slate-900">easy2gohub@gmail.com</span>.
      </p>
    </div>
  </section>
</ToolLayout>