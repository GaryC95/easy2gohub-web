---
import HomeLayout from "../layouts/HomeLayout.astro";
import AdsSlot from "../components/ads/AdsSlot.astro";
import {
  CATEGORY_META,
  getToolsByCategory,
  getActiveCategories,
} from "../data/tools";

import HomeHeroA1 from "../components/home/HomeHeroA1.astro";
import PopularToolsRow from "../components/home/PopularToolsRow.astro";
import TrustStrip from "../components/home/TrustStrip.astro";
import CategoriesSection from "../components/home/CategoriesSection.astro";

const title = "Free Online Image Tools – Compress, Resize & Convert | Easy2GoHub";
const description =
  "Free online image tools to compress, resize & convert JPG/PNG/WebP/HEIC — runs locally in your browser. No uploads. Fast results.";
const canonical = "https://www.easy2gohub.com/";

const activeCats = getActiveCategories();
const imageTools = getToolsByCategory("image");

// 首页广告策略：default/heavy 展示更完整；light 更克制
const adsProfile: "light" | "default" | "heavy" = "default";
const showInFeed = adsProfile !== "light";
const showExtraBox = adsProfile === "heavy";

// A1: Popular tools（沿用你的 imageTools 前 4 个逻辑）
const featuredTools = imageTools.slice(0, 4);

// 预计算分类数据（不改逻辑，只把 map 拿到 index 层做）
const categories = activeCats.map((cat) => ({
  cat,
  meta: CATEGORY_META[cat],
  list: getToolsByCategory(cat),
}));
---

<HomeLayout
  title={title}
  headerTitle="Easy2GoHub"
  description={description}
  canonical={canonical}
  adsProfile={adsProfile}
>
  {/* ✅ A1: Hero（居中/无按钮/更满） + Popular tools + Trust strip */}
  <HomeHeroA1>
    <PopularToolsRow title="Popular tools" tools={featuredTools} moreHref="/image/" moreLabel="Image tools" />
    <TrustStrip />
  </HomeHeroA1>

  {/* ✅ In-feed Banner (high viewability, low distraction) */}
  {showInFeed ? (
    <section class="mt-6">
      <div class="hidden md:block">
        <AdsSlot label="Home – In-feed Banner" variant="banner" height={120} className="w-full" />
      </div>
      <div class="md:hidden">
        <AdsSlot label="Home – In-feed Banner" variant="banner" height={100} className="w-full" />
      </div>
    </section>
  ) : null}

  {/* ✅ Categories（保留原逻辑：循环 + ToolGrid + 广告插入点） */}
  <CategoriesSection
    categories={categories}
    showInFeed={showInFeed}
    showExtraBox={showExtraBox}
  />
</HomeLayout>