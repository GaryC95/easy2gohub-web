---
import ToolLayout from "../layouts/ToolLayout.astro";

const title = "Terms of Service";
const description =
  "Easy2GoHub Terms of Service: acceptable use, disclaimers, limitations of liability, and contact information.";
const canonical = "https://www.easy2gohub.com/terms/";
---

<ToolLayout title={title} description={description} canonical={canonical} adsProfile="none">
  <section class="tool-card p-10 space-y-6">
    <h1 class="text-3xl font-semibold text-slate-900 text-center">Terms of Service</h1>

    <p class="text-slate-700 leading-relaxed max-w-3xl mx-auto">
      By accessing or using Easy2GoHub, you agree to these Terms of Service. If you do not agree, please do not use the
      website.
    </p>

    <div class="space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">1) Use of the Website</h2>
      <p class="text-slate-700 leading-relaxed">
        Easy2GoHub provides browser-based utilities, currently focused on image tools. You agree to use the site only for
        lawful purposes and in a way that does not violate any applicable laws or regulations.
      </p>
    </div>

    <div class="space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">2) Local Processing Disclaimer</h2>
      <p class="text-slate-700 leading-relaxed">
        Most tools process files locally in your browser. Your files are not uploaded to our servers by default. However,
        you are responsible for the content you process and how you use the outputs.
      </p>
    </div>

    <div class="space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">3) No Warranty</h2>
      <p class="text-slate-700 leading-relaxed">
        The website and tools are provided “as is” without warranties of any kind. We do not guarantee accuracy,
        availability, or suitability for any specific purpose.
      </p>
    </div>

    <div class="space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">4) Limitation of Liability</h2>
      <p class="text-slate-700 leading-relaxed">
        To the maximum extent permitted by law, Easy2GoHub shall not be liable for any indirect, incidental, special, or
        consequential damages arising out of or related to your use of the website or tools.
      </p>
    </div>

    <div class="space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">5) Third-Party Services (Ads / Analytics)</h2>
      <p class="text-slate-700 leading-relaxed">
        The site may use third-party services such as analytics or advertising (for example, Google AdSense). These services
        may collect information via cookies or similar technologies according to their own policies.
      </p>
    </div>

    <div class="space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">6) Changes</h2>
      <p class="text-slate-700 leading-relaxed">
        We may update these terms at any time. Continued use of the site means you accept the updated terms.
      </p>
    </div>

    <div class="space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">7) Contact</h2>
      <p class="text-slate-700 leading-relaxed">
        If you have questions about these terms, contact:
        <span class="font-semibold text-slate-900"> easy2gohub@gmail.com</span>
      </p>
    </div>
  </section>
</ToolLayout>